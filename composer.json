{
    "name": "locus/attendance-app",
    "description": "Locus - Sistema de gestion de asistencias con QR y geolocalizacion",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration tests/phpunit.xml",
        "serve": "php -S localhost:8000 -t public public/index.php"
    }
}
